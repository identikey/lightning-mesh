# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

**/*.trace
**/*.zip
**/*.tar.gz
**/*.tgz
**/*.log
package-lock.json
**/*.bun
.omc
/target/
.omx

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# MikroTik container build artifacts
deploy/mikrotik/*.tar

# OpenWrt native build artifact (static aarch64 binary; rebuild with deploy/openwrt/build.sh)
deploy/openwrt/*-aarch64

# Prefetched OpenWrt packages (install-node.sh fills this from any node with
# feed access; pushed to nodes without WAN). Re-fetchable, release-specific.
deploy/openwrt/pkg-cache/

# Official MikroTik RouterOS packages (large binaries, MikroTik's to distribute).
# Re-download with deploy/mikrotik/fetch-firmware.sh.
deploy/mikrotik/*.npk

# meshctl per-router node secrets (IROH_SECRET) — never commit
deploy/mikrotik/secrets/

# OpenWrt fleet secrets (MESH_KEY/CLIENT_KEY/FT_KEY wireless env) — never
# commit; only the checked-in .example template survives this ignore.
deploy/openwrt/fleet-secrets/*
!deploy/openwrt/fleet-secrets/*.example
