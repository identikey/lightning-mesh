# Fleet wireless secrets — TEMPLATE. The real file is gitignored:
#
#   cp wireless.env.example wireless.env     # then fill in real values
#   deploy/openwrt/update-fleet.sh --wireless deploy/openwrt/fleet-secrets/wireless.env
#
# The file is sourced (set -a) by mjolnir-apply on the node before running
# setup-wireless.sh, so ANY variable from setup-wireless.sh's header can be
# overridden here. It is wiped from the node's staging dir after the apply;
# the values live on in /etc/config/wireless (that's their job).
#
# Everything here is FLEET-WIDE: same values on every node or the mesh
# won't form / clients won't roam. Rotating a value = one fleet rollout.

MESH_ID='mjolnir-mesh'
MESH_KEY=''              # empty = OPEN mesh (current fleet state). Set to enable
                         # 802.11s SAE encryption on the backhaul, fleet-wide.
CLIENT_SSID='Lightning Mesh'
CLIENT_KEY='lightning!'  # CHANGE for a real deployment — this default is public
                         # in git (setup-wireless.sh) and is NOT a secret.
FT_KEY=''                # 802.11r key-holder push secret, 64 hex chars (bnd).
                         # Empty = fast transition off. Generate with:
                         #   openssl rand -hex 32
# COUNTRY='DE'
# MESH_CHANNEL_2G='6'
# CLIENT_CHANNEL_5G='36'
