#!/bin/sh /etc/rc.common
# procd init script for iperf3-server — always-on `iperf3 -s` listener so any
# node-to-node throughput can be measured on demand with zero setup
# (mjolnir-mesh-81n). Pure measurement tool: no mesh state, no config file,
# independent of meshd/babeld/hello.
#
# Install:
#   scp this file -> /etc/init.d/iperf3-server ; chmod +x
#   opkg/apk install iperf3
#   /etc/init.d/iperf3-server enable && /etc/init.d/iperf3-server start

USE_PROCD=1
START=99
STOP=05

PROG=/usr/bin/iperf3

start_service() {
	[ -x "$PROG" ] || return 0

	procd_open_instance iperf3-server
	procd_set_param command "$PROG" -s
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}
