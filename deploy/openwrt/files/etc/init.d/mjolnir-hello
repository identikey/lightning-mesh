#!/bin/sh /etc/rc.common
# procd init script for mjolnir-hello — the hello.mesh front desk (static
# frontend + read-only mesh API). OPTIONAL: a node runs the mesh fine without
# this service. Config lives in /etc/config/mjolnir, section 'hello' (S7,
# bead mjolnir-mesh-eei). See deploy/openwrt/README.md.
#
# Install:
#   scp this file -> /etc/init.d/mjolnir-hello ; chmod +x
#   scp the static binary -> /usr/bin/mjolnir-hello
#   edit /etc/config/mjolnir (section 'hello': enabled='1'), then:
#     service mjolnir-hello start

USE_PROCD=1
# After meshd (95) and babeld (96): the front desk reads the directory.json
# meshd writes and the pending/ spool meshd drains, so start once those paths
# exist. Not on meshd's critical path — a hello crash/absence never affects
# the mesh itself.
START=97
STOP=08

PROG=/usr/bin/mjolnir-hello

start_service() {
	local enabled lan_iface port directory_file spool_dir lan_ip bind

	config_load mjolnir
	config_get_bool enabled hello enabled 0
	[ "$enabled" -gt 0 ] || return 0

	config_get lan_iface      hello lan_iface      'lan'
	config_get port           hello port           '80'
	config_get directory_file hello directory_file '/var/run/mjolnir/directory.json'
	config_get spool_dir      hello spool_dir       '/var/run/mjolnir/pending'

	# Resolve the node's LAN gateway IP from the LAN logical interface (netifd),
	# independent of .mesh resolution (a separate track, mjolnir-mesh-e21).
	. /lib/functions/network.sh
	network_flush_cache
	network_get_ipaddr lan_ip "$lan_iface"
	if [ -z "$lan_ip" ]; then
		logger -t mjolnir-hello "no IP on logical interface '$lan_iface' yet — not starting (will retry on next start_service)"
		return 0
	fi
	bind="${lan_ip}:${port}"

	mkdir -p "$(dirname "$directory_file")" "$spool_dir" 2>/dev/null

	procd_open_instance hello
	procd_set_param command "$PROG"
	procd_append_param command --bind "$bind"
	procd_append_param command --directory-file "$directory_file"
	procd_append_param command --spool-dir "$spool_dir"
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger mjolnir
}
