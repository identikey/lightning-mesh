# UCI config for mjolnir-meshd. Read by /etc/init.d/mjolnir-meshd.
# Reload after edits:  service mjolnir-meshd restart

config meshd 'meshd'
	option enabled '1'

	# The L2 the overlay peers over (meshd self-assigns its 10.254.x backhaul
	# address here and babel runs over it as `type wired`).
	#   - WIRED bench bring-up: set to the bridge carrying the management switch,
	#     usually 'br-lan'.
	#   - 802.11s radio backhaul: use 'br-mesh' (created by setup-wireless.sh).
	option backhaul_iface 'br-mesh'

	# Client-facing bridge serving this node's devices. meshd assigns the claimed
	# /24's .1 here as a connected route babeld redistributes. A dedicated client
	# bridge is cleanest in production; 'br-lan' is fine for the bench.
	option client_iface 'br-lan'

	option secret_file '/etc/mjolnir/secret'
	option babeld 'babeld'
	option babel_config '/etc/mjolnir/babeld.conf'

	# Transport mode: 'lan' (offline mDNS, no relay) or 'internet' (n0/relay).
	option mode 'lan'
	# option relay 'https://your-relay.example/'   # only when mode='internet'

	# auu retest: re-enable per-peer iroh tunnels in LAN mode (default 0 = data
	# rides the shared-L2 backhaul, babel-routed). Flip to 1 on a test node to
	# verify the same-site tunnel stays up natively (mjolnir-mesh-auu / 0yb.1).
	option lan_tunnels '0'

	# a8o: internet-gateway role. Set to 1 on a node whose WAN port has real
	# upstream internet: it redistributes its default route into the mesh
	# (0.0.0.0/0, metric 128) and every other node — and their clients —
	# egresses through it, NAT'd by the standard wan-zone masquerade. Safe on
	# several nodes at once (babel picks the nearest exit) and self-withdraws
	# when the uplink drops. Default 0.
	# option gateway '1'

	option log_level 'info'

	# Peers = the OTHER nodes' iroh node-ids (64-hex) or address blobs. Repeat.
	# Print a node's id with:
	#   mjolnir-meshd id --secret-file /etc/mjolnir/secret
	# list peer '<node-id-of-another-router>'
	# list peer '<node-id-of-another-router>'

# mjolnir-hello: hello.mesh front desk (static frontend + read-only mesh API).
# OPTIONAL — the mesh runs fine without it (S7, bead mjolnir-mesh-eei). Reload
# after edits:  service mjolnir-hello restart
config hello 'hello'
	option enabled '0'

	# Logical netifd interface (see /etc/config/network) whose IP the init
	# script binds to — the node's LAN gateway address, independent of .mesh
	# resolution (a separate track, mjolnir-mesh-e21). 'lan' is OpenWrt's
	# default logical name for br-lan.
	option lan_iface 'lan'
	option port '80'

	# Daemon seams shared with mjolnir-meshd: it writes directory_file and
	# drains spool_dir (docs/network-coordination/hello-mesh-service.md §1/§3).
	# Keep these identical to meshd's own paths.
	option directory_file '/var/run/mjolnir/directory.json'
	option spool_dir '/var/run/mjolnir/pending'
